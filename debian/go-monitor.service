[Unit]
Description=System Resource Monitor
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/etc/go-monitor
ExecStart=/usr/bin/go-monitor -config /etc/go-monitor/config.yaml
Restart=on-failure
RestartSec=5

# Security hardening
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
NoNewPrivileges=true
ReadWritePaths=/etc/go-monitor

[Install]
WantedBy=multi-user.target